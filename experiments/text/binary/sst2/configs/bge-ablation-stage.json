{
  "experiment_name": "sst2-bge-ablation-stage",
  "dataset": {
    "loader": "glue",
    "path": "glue",
    "name": "sst2",
    "text_column": "sentence",
    "label_column": "label",
    "train_split": "train",
    "validation_split": "validation"
  },
  "model": {
    "name": "BAAI/bge-base-en-v1.5",
    "slug": "bge-base-en-v1-5"
  },
  "embedding": {
    "pooling": "mean",
    "max_length": 64,
    "batch_size": 32
  },
  "variants": [
    {
      "name": "raw-meanpool",
      "embedding_key": "raw"
    },
    {
      "name": "l2-meanpool",
      "embedding_key": "l2"
    },
    {
      "name": "centered-l2-meanpool",
      "embedding_key": "centered_l2"
    }
  ],
  "evaluation": {
    "knn_k_values": [1, 5],
    "logistic_max_iter": 2000,
    "random_seed": 42
  }
}
